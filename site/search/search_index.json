{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":[" "]},"docs":[{"location":"","title":"\ubb49\uc0b4\ud769\uc8fd \ud504\ub85c\uc81d\ud2b8","text":""},{"location":"#_2","title":"\ud504\ub85c\uc81d\ud2b8 \uac1c\uc694","text":"<p>\ubcf8 \ud504\ub85c\uc81d\ud2b8\ub294 \ud604\ub300\uc801\uc778 \ud074\ub77c\uc6b0\ub4dc \ubcf4\uc548 \uc704\ud611\uc5d0 \ub300\uc751\ud558\uae30 \uc704\ud574 AWS \uce68\ud574\uc0ac\uace0 \uc0ac\ub840\uc640 \uae30\uc874 \ubcf4\uc548 \uc544\ud0a4\ud14d\ucc98\ub97c \ubd84\uc11d\ud558\uc5ec \ube44\uc988\ub2c8\uc2a4 \uaddc\ubaa8\uc5d0 \ucd5c\uc801\ud654\ub41c \ubcf4\uc548 \uc544\ud0a4\ud14d\ucc98\ub97c \uc81c\uc2dc\ud558\ub294 \uac83\uc744 \ubaa9\uc801\uc73c\ub85c \ud569\ub2c8\ub2e4.</p>"},{"location":"#_3","title":"\ud83d\udcc2 \uc8fc\uc694 \uc139\uc158 \uc548\ub0b4","text":"<p>\uc544\ub798 \uc139\uc158\uc744 \ud1b5\ud574 \uc0c1\uc138 \ub0b4\uc6a9\uc744 \ud655\uc778\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <ul> <li>\uce68\ud574\uc0ac\uace0 \ubd84\uc11d: \uc2e4\uc81c \ubc1c\uc0dd\ud588\ub358 \ud074\ub77c\uc6b0\ub4dc \ubcf4\uc548 \uc0ac\uace0\uc758 \uacf5\uaca9 \uae30\ubc95\uacfc \ub300\uc751 \ubc29\uc548\uc744 \ub2e4\ub8f9\ub2c8\ub2e4.</li> <li>\uc778\ud504\ub77c \ubd84\uc11d: \ud604\uc5c5\uc5d0\uc11c \uc0ac\uc6a9\ud558\ub294 \ud074\ub77c\uc6b0\ub4dc \uc778\ud504\ub77c\ub97c \ubcf4\uc548 \uad00\uc810\uc5d0\uc11c \ubd84\uc11d\ud569\ub2c8\ub2e4.</li> <li>\uc544\ud0a4\ud14d\ucc98 \uc124\uacc4: \ube44\uc988\ub2c8\uc2a4 \uc131\uc7a5 \ub2e8\uacc4\ubcc4\ub85c \uc801\uc6a9 \uac00\ub2a5\ud55c \ud45c\uc900 \ubcf4\uc548 \uc124\uacc4\ub3c4\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"#_4","title":"\ud83d\udc65 \ud300\uc6d0 \uc18c\uac1c","text":"\uc774\ub984 \ub2f4\ub2f9 \ud30c\ud2b8 \ube44\uace0 \uc870\ud718\uc815(PM) \uce68\ud574\uc0ac\uace0 \ubd84\uc11d (Lead) AWS Security Specialist \uae40\ubbfc\uc218 \uc778\ud504\ub77c \ubd84\uc11d DevSecOps Engineer \uc774\uc9c0\ud5a5 \uc544\ud0a4\ud14d\ucc98 \uc124\uacc4 Cloud Architect \uc774\ud638\uc601 \uc544\ud0a4\ud14d\ucc98 \uc124\uacc4 Cloud Architect <p>!!! info \"\uacf5\uc9c0\uc0ac\ud56d\"     \ubaa8\ub4e0 \ubd84\uc11d \ub0b4\uc6a9\uc740 \uc9c0\uc18d\uc801\uc73c\ub85c \uc5c5\ub370\uc774\ud2b8\ub420 \uc608\uc815\uc785\ub2c8\ub2e4.</p>"},{"location":"01-incident/case-01/","title":"\ubd84\uc11d \uc0ac\ub840 \uc81c\ubaa9 (\uc608: Capital One \ub370\uc774\ud130 \uc720\ucd9c \ubd84\uc11d)","text":""},{"location":"01-incident/case-01/#1","title":"1. \uac1c\uc694","text":""},{"location":"01-incident/case-01/#11","title":"1.1 \uc0ac\uace0 \ubc30\uacbd","text":"<p>\ub0b4\uc6a9\uc744 \uc785\ub825\ud558\uc138\uc694.</p>"},{"location":"01-incident/case-01/#12","title":"1.2 \uc0ac\uace0 \uc694\uc57d","text":"<p>\ub0b4\uc6a9\uc744 \uc785\ub825\ud558\uc138\uc694.</p>"},{"location":"01-incident/case-01/#2","title":"2. \uacf5\uaca9 \ubd84\uc11d","text":""},{"location":"01-incident/case-01/#21-attack-flow","title":"2.1 \uacf5\uaca9 \ud750\ub984 (Attack Flow)","text":"<p>\ub0b4\uc6a9\uc744 \uc785\ub825\ud558\uc138\uc694.</p>"},{"location":"01-incident/case-01/#22","title":"2.2 \ub2e8\uacc4\ubcc4 \uacf5\uaca9 \ud504\ub85c\uc138\uc2a4","text":"<p>\ub0b4\uc6a9\uc744 \uc785\ub825\ud558\uc138\uc694.</p>"},{"location":"01-incident/case-01/#3","title":"3. \ub300\uc751 \ubc29\uc548","text":""},{"location":"01-incident/case-01/#31","title":"3.1 \uc989\uac01 \ub300\uc751 \uc808\ucc28","text":"<p>\ub0b4\uc6a9\uc744 \uc785\ub825\ud558\uc138\uc694.</p>"},{"location":"01-incident/case-01/#32","title":"3.2 \uc0ac\ud6c4 \uc870\uce58 \ubc0f \uc7ac\ubc1c \ubc29\uc9c0","text":"<p>\ub0b4\uc6a9\uc744 \uc785\ub825\ud558\uc138\uc694.</p>"},{"location":"01-incident/case-02/","title":"\ubd84\uc11d \uc0ac\ub840 \uc81c\ubaa9 (\uc608: Onus \ub370\uc774\ud130 \uc720\ucd9c \ubd84\uc11d)","text":""},{"location":"01-incident/case-02/#1","title":"1. \uac1c\uc694","text":""},{"location":"01-incident/case-02/#11","title":"1.1 \uc0ac\uace0 \ubc30\uacbd","text":"<p>\ub0b4\uc6a9\uc744 \uc785\